@model SportClub.BLL.DTO.CoachDTO
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "CoachProfile";
}
<h4 class="myRegTitleProf whiteY">
    @Resources.Resource.Profile
</h4>

<div class="flex" style="justify-content:center;">
    <div class="div_n1 div_reg2">
        <form method="post" enctype="multipart/form-data">
            <div class="flex" style="justify-content:center;">
                
                <div class="f_g form-group">
                    <img src=@Model.Photo width="130" alt="photo1" class="coachProfPhoto" id="preview" />

                    <span class="white-color_size20 font">@Resources.Resource.Photo</span><br />
                    <input class="white-color_size20" type="file" name="p" accept=".jpg, .jpeg, .png" onchange="previewImage(event)" style="width:300px;" /><br />
                </div>
            </div>
            <hr class="whiteY" />
            <div class="row">
                <div>
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    @Html.AntiForgeryToken()
                    @* width: 500px; *@
                    <div class="row">
                        @Html.ValidationSummary(true, "")
                        <div style="  justify-content: center; ">
                            <div class="form-group_v1">
                                <label asp-for="Name" class="control-label whiteY" class="font">@Resources.Resource.Name</label>
                                <input asp-for="Name" type="text" class="form-control_v1" name="name" id="name" class="font">
                                <span asp-validation-for="Name" class="text-danger" style="width: 450px"></span>
                            </div>
                            <div class="form-group_v1">
                                <label asp-for="Login" class="control-label whiteY" class="font">@Resources.Resource.Login</label>
                                <input asp-for="Login" type="text" class="form-control_v1" name="login" id="login">
                                <span asp-validation-for="Login" class="text-danger" style="width: 450px"></span>
                            </div>

                            <div class="form-group_v1">
                                <label asp-for="Email" class="control-label whiteY" class="font">@Resources.Resource.email</label>
                                <input asp-for="Email" class="form-control_v1" id="emailInput">
                                <span asp-validation-for="Email" class="text-danger" style="width: 450px"></span>
                            </div>

                            <div class="form-group_v1">
                                <label asp-for="Phone" class="font whiteY">@Resources.Resource.Phone</label>
                                <input asp-for="Phone" class="form-control_v1" placeholder="+380971234567" />
                                <span asp-validation-for="Phone" class="text-danger" style="width: 450px"></span>
                            </div>
                            <div class="form-group_v1">
                                <label class="font whiteY">@Resources.Resource.gender</label>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="Gender" value="Мужской" id="male" />
                                    <label style="color: white" class="font form-check-label" for="male">@Resources.Resource.man</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="Gender" value="Женский" id="female" />
                                    <label style="color: white" class="font form-check-label" for="female">@Resources.Resource.female</label>
                                </div>
                            </div>
                            <div class="form-group_v1">
                                <label class="font whiteY">@Resources.Resource.DateB</label><br />
                                <input asp-for="DateOfBirth" type="text" />
                                <br />
                                <span asp-validation-for="DateOfBirth" class="text-danger" style="width: 450px"></span>
                            </div>
                            <br />


                            <div class="flex" style="justify-content:space-around;">
                                <input type="submit" class="btn btn-outline-light buttonsGY" formaction="EditCoachProfile" style="min-width:150px;" value="@Resources.Resource.Confirm" />
                                <input class="btn btn-outline-light buttonsGY" formaction="ChangeCoachPassword" type="submit" style="min-width:150px;" value="@Resources.Resource.Edit &nbsp;@Resources.Resource.password" />

                            </div>
                            <br />
                            <br />
                        </div>
                    </div>

                </div>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
<script>
    $(document).ready(function () {

        $("#login").on("change", function (e) {
            let log = e.target.value;
            let r = true;
            $.getJSON('/Login/IsLoginIn', function (data) {
                $.each(data, function (key, val) {
                    if (log == val) {
                        $("#log").css("display", "block");
                        r = false;
                    }
                    if (r) {
                        $("#log").css("display", "none");
                    }
                })
            });
        });


        $('#emailInput').on('blur', function () {
            var email = $(this).val();
            $.get('/Login/IsEmailInUse', { email: email }, function (data) {
                if (data === true) {
                    $('#emailStatus').text('Email уже занят.');
                }
            });
        });
    });

    function previewImage(event) {
        var input = event.target;
        var preview = document.getElementById('preview');

        var reader = new FileReader();

        reader.onload = function () {
            preview.src = reader.result;
        };

        reader.readAsDataURL(input.files[0]);
    }
</script>

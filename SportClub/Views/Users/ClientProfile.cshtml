@model SportClub.BLL.DTO.UserDTO

@{
    ViewData["Title"] = "ClientProfile";
}
@using Microsoft.AspNetCore.Http

<h4 class="myRegTitleProf whiteY">
    @Resources.Resource.PersonalInformation
</h4>

<div class="container2">
    <form id="registrationForm" action="RegistrationClient" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "")

        <div class="row" style="padding-top: 30px;">
            <div class="column">
                <div class="form-groupProf">
                    <label asp-for="Name" class="control-label font white-color_size20 color_text">@Resources.Resource.Name:</label>
                    <input asp-for="Name" class="form-control" type="text" class="font" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <input type="hidden" asp-for="Id" />
                <div class="form-groupProf">
                    <label asp-for="Login" class="control-label font white-color_size20 color_text">@Resources.Resource.loginN:</label>
                    <input asp-for="Login" class="form-control" type="text" class="font" id="login" />
                    <span asp-validation-for="Login" class="text-danger"></span>
                </div>

                <div class="form-groupProf" >
                    <label asp-for="Email" class="control-label font white-color_size20 color_text">@Resources.Resource.email:</label>
                    <input asp-for="Email" class="form-control" type="email" class="font" id="emailInput" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-groupProf">
                    <label asp-for="Phone" class="control-label font white-color_size20 color_text">@Resources.Resource.Phone:</label>
                    <input asp-for="Phone" class="form-control" type="text" class="font" placeholder="+380971234567" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="form-groupProf">
                    <label class="control-label font white-color_size20 color_text">@Resources.Resource.gender:</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Gender" value="Мужской" id="male" />
                        <label class="form-check-label font white-color_size20 color_text" for="male">@Resources.Resource.man:</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Gender" value="Женский" id="female" />
                        <label class="form-check-label font white-color_size20 color_text" for="female">@Resources.Resource.female:</label>
                    </div>
                </div>

                <div class="form-groupProf">
                    <label asp-for="DateOfBirth" class="control-label font white-color_size20 color_text">@Resources.Resource.DateB:</label>
                    <input asp-for="DateOfBirth" class="form-control" type="text" class="font" id="login" />
                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                </div>
            </div>
        </div>
        <br />
        <div class="form-group" style="padding-bottom:20px;">
            <input type="submit" style="margin-right: 10px" class="btn btn-outline-light buttonsGY" formaction="EditClientProfile" value="@Resources.Resource.Edit" />
            <input class="btn btn-outline-light buttonsGY" style="margin-right: 10px" formaction="ChangeClientPassword" type="submit" value="@Resources.Resource.changePassword" />
            <input type="submit" class="mbtnb btn btn-outline-light buttonsGY" formaction="DeleteClientProfile" value="@Resources.Resource.DeleteAndExit" />
        </div>
        <br />
    </form>
</div>
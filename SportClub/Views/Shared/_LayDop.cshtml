            background-image: linear-gradient(to bottom right, #2F4F4F, #2F3F2F);
        }

        .div_reg2_1 {
            /*  background-color: #2F4F4F; */
            box-shadow: inset 3em -3em 3em rgba(0, 0, 0, 0.1), 0.3em 0.3em 1em dimgray;
            border-radius: 5px;
            background-image: linear-gradient(to bottom right, #2F4F4F, #2F3F2F);
        }

        .div_reg p {
            font-size: 32px;
            color: white;
            padding-top: 30px;
            text-align: center
        }

        .div_reg p1 {
            font-size: 20px;
            color: white;
            text-align: center
